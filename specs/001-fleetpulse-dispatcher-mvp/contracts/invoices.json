{
  "api": "Invoices",
  "version": "1.0.0",
  "baseUrl": "/api/v1/invoices",
  "description": "Invoice tracking and follow-up management for dispatcher and carrier payment monitoring.",
  "endpoints": [
    {
      "name": "List Invoices",
      "method": "GET",
      "path": "/",
      "description": "Fetch invoices (dispatcher view across org, or carrier self-view)",
      "auth": "Bearer (dispatcher_admin, carrier_*)",
      "queryParams": {
        "type": "object",
        "properties": {
          "carrier_id": {
            "type": "string",
            "format": "uuid",
            "description": "Filter by carrier (dispatcher only)"
          },
          "status": {
            "type": "string",
            "enum": ["draft", "sent", "paid", "overdue"],
            "description": "Filter by invoice status"
          },
          "days_outstanding_min": {
            "type": "integer",
            "description": "Min days overdue (filters on GENERATED column)"
          },
          "days_outstanding_max": {
            "type": "integer",
            "description": "Max days overdue"
          },
          "sort_by": {
            "type": "string",
            "enum": ["issued_date", "due_date", "days_outstanding", "amount"],
            "default": "days_outstanding",
            "description": "Sort column"
          },
          "order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "default": "desc",
            "description": "Sort direction"
          },
          "limit": { "type": "integer", "default": 50, "maximum": 500 },
          "offset": { "type": "integer", "default": 0 }
        }
      },
      "responses": {
        "200": {
          "description": "Invoice list (RLS-scoped)",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": { "$ref": "#/definitions/Invoice" }
              },
              "meta": {
                "type": "object",
                "properties": {
                  "total": { "type": "integer" },
                  "total_outstanding": {
                    "type": "number",
                    "description": "Sum of (amount where status != paid)"
                  },
                  "limit": { "type": "integer" },
                  "offset": { "type": "integer" }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "name": "Get Invoice Details",
      "method": "GET",
      "path": "/{invoice_id}",
      "description": "Fetch single invoice with load details, follow-ups, and carrier contact",
      "auth": "Bearer",
      "pathParams": {
        "invoice_id": { "type": "string", "format": "uuid" }
      },
      "responses": {
        "200": {
          "description": "Invoice detail",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "allOf": [{ "$ref": "#/definitions/Invoice" }],
                "properties": {
                  "load": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "pickup_date": { "type": "string", "format": "date" },
                      "delivery_date": { "type": "string", "format": "date" },
                      "rate": { "type": "number" },
                      "miles": { "type": "integer" },
                      "net_profit": { "type": "number" },
                      "ai_recommendation": { "type": "string" }
                    }
                  },
                  "carrier": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "legal_name": { "type": "string" },
                      "contact_name": { "type": "string" },
                      "contact_email": { "type": "string" },
                      "contact_phone": { "type": "string" }
                    }
                  },
                  "broker": {
                    "type": "object",
                    "properties": {
                      "id": { "type": "string", "format": "uuid" },
                      "legal_name": { "type": "string" },
                      "mc_number": { "type": "string" }
                    }
                  },
                  "followups": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "followup_count": { "type": "integer" },
                        "tone": { "type": "string" },
                        "drafted_at": { "type": "string", "format": "date-time" },
                        "sent_at": { "type": "string", "format": "date-time", "nullable": true },
                        "draft_message": { "type": "string" }
                      }
                    }
                  }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "404": {
          "description": "Invoice not found or not in scope",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string" },
              "error_code": { "type": "string", "example": "NOT_FOUND" }
            }
          }
        }
      }
    },
    {
      "name": "Update Invoice Status",
      "method": "PATCH",
      "path": "/{invoice_id}",
      "description": "Mark invoice as sent, paid, or overdue",
      "auth": "Bearer (dispatcher_admin)",
      "pathParams": {
        "invoice_id": { "type": "string", "format": "uuid" }
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string",
            "enum": ["draft", "sent", "paid", "overdue"],
            "description": "New status"
          },
          "paid_date": {
            "type": "string",
            "format": "date",
            "description": "Required if status=paid"
          },
          "send_followup_now": {
            "type": "boolean",
            "default": false,
            "description": "If true and status=sent, also generate AI follow-up draft"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Invoice updated",
          "body": {
            "type": "object",
            "properties": {
              "data": { "$ref": "#/definitions/Invoice" },
              "followup_drafted": {
                "type": "boolean",
                "description": "true if send_followup_now triggered AI generation"
              },
              "error": { "type": "null" }
            }
          }
        },
        "400": {
          "description": "Invalid transition or missing required field",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "paid_date required when status=paid" },
              "error_code": { "type": "string", "enum": ["VALIDATION_ERROR", "INVALID_STATE_TRANSITION"], "example": "VALIDATION_ERROR" }
            }
          }
        }
      }
    },
    {
      "name": "Generate Follow-up Draft",
      "method": "POST",
      "path": "/{invoice_id}/followup",
      "description": "Manually request AI follow-up draft for an invoice",
      "auth": "Bearer (dispatcher_admin)",
      "pathParams": {
        "invoice_id": { "type": "string", "format": "uuid" }
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "override_tone": {
            "type": "string",
            "enum": ["polite", "firm", "assertive", "final"],
            "description": "Force tone (normally auto-selected by days_outstanding)"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Follow-up draft generated or retrieved from cache",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "invoice_id": { "type": "string", "format": "uuid" },
                  "followup_count": { "type": "integer" },
                  "tone": { "type": "string" },
                  "draft_message": { "type": "string" },
                  "subject_line": { "type": "string" },
                  "cache_hit": { "type": "boolean" },
                  "days_outstanding": { "type": "integer" }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "Invoice": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organization_id": { "type": "string", "format": "uuid" },
        "load_id": { "type": "string", "format": "uuid" },
        "carrier_id": { "type": "string", "format": "uuid" },
        "broker_id": { "type": "string", "format": "uuid" },
        "amount": {
          "type": "number",
          "example": 2500,
          "description": "Invoice amount in USD"
        },
        "issued_date": {
          "type": "string",
          "format": "date",
          "description": "Date invoice auto-created from load"
        },
        "due_date": {
          "type": "string",
          "format": "date",
          "description": "Usually issued_date + 15 days (configurable per carrier tier)"
        },
        "paid_date": {
          "type": "string",
          "format": "date",
          "nullable": true,
          "description": "Date payment received"
        },
        "days_outstanding": {
          "type": "integer",
          "description": "GENERATED ALWAYS AS (CURRENT_DATE - issued_date); used for aging bucket calculations"
        },
        "status": {
          "type": "string",
          "enum": ["draft", "sent", "paid", "overdue"],
          "description": "draft (unsent), sent (waiting), paid, or overdue (30+ days)"
        },
        "follow_up_count": {
          "type": "integer",
          "default": 0,
          "description": "Number of AI follow-up drafts generated for this invoice"
        },
        "ai_followup_draft": {
          "type": "string",
          "nullable": true,
          "description": "Latest AI-generated follow-up message (if any)"
        },
        "ai_followup_response_id": {
          "type": "string",
          "format": "uuid",
          "nullable": true,
          "description": "Reference to ai_responses table for auditability"
        },
        "factoring_eligible": {
          "type": "boolean",
          "default": true,
          "description": "true if invoice can be used for freight factoring programs (Phase 3)"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
