{
  "api": "Authentication",
  "version": "1.0.0",
  "baseUrl": "/api/v1/auth",
  "endpoints": [
    {
      "name": "Signup",
      "method": "POST",
      "path": "/signup",
      "description": "Create a new dispatcher account and organization",
      "auth": "none",
      "requestBody": {
        "type": "object",
        "required": ["email", "password", "full_name", "company_name"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string", "minLength": 8 },
          "full_name": { "type": "string" },
          "company_name": { "type": "string" }
        }
      },
      "responses": {
        "201": {
          "description": "Account created successfully",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "user": { "$ref": "#/definitions/User" },
                  "session": { "$ref": "#/definitions/Session" },
                  "organization": { "$ref": "#/definitions/Organization" }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "400": {
          "description": "Validation error (email in use, weak password)",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "Email already registered" },
              "error_code": { "type": "string", "enum": ["VALIDATION_ERROR", "EMAIL_IN_USE", "WEAK_PASSWORD"], "example": "EMAIL_IN_USE" }
            }
          }
        }
      }
    },
    {
      "name": "Login",
      "method": "POST",
      "path": "/login",
      "description": "Authenticate dispatcher or carrier",
      "auth": "none",
      "requestBody": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": { "type": "string", "format": "email" },
          "password": { "type": "string" }
        }
      },
      "responses": {
        "200": {
          "description": "Login successful",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "user": { "$ref": "#/definitions/User" },
                  "session": { "$ref": "#/definitions/Session" },
                  "access_token": { "type": "string" }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "401": {
          "description": "Invalid credentials",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "Invalid email or password" },
              "error_code": { "type": "string", "example": "AUTH_FAILED" }
            }
          }
        }
      }
    },
    {
      "name": "Invite Carrier to Portal",
      "method": "POST",
      "path": "/invite/carrier",
      "description": "Send magic link invite to carrier email",
      "auth": "Bearer (dispatcher_admin only)",
      "requestBody": {
        "type": "object",
        "required": ["carrier_id", "email"],
        "properties": {
          "carrier_id": { "type": "string", "format": "uuid" },
          "email": { "type": "string", "format": "email" },
          "access_level": { "type": "string", "enum": ["carrier_free", "carrier_pro"] }
        }
      },
      "responses": {
        "200": {
          "description": "Invite sent",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "sent": { "type": "boolean", "example": true },
                  "email": { "type": "string" },
                  "expires_in_hours": { "type": "integer", "example": 24 }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "403": {
          "description": "Not authorized",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "dispatcher_admin role required" },
              "error_code": { "type": "string", "example": "UNAUTHORIZED_ROLE" }
            }
          }
        }
      }
    },
    {
      "name": "Accept Carrier Invite",
      "method": "POST",
      "path": "/accept-invite",
      "description": "Activate carrier account from magic link",
      "auth": "none",
      "requestBody": {
        "type": "object",
        "required": ["token", "password"],
        "properties": {
          "token": { "type": "string", "description": "Magic link token from email" },
          "password": { "type": "string", "minLength": 8 }
        }
      },
      "responses": {
        "200": {
          "description": "Account activated",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "user": { "$ref": "#/definitions/User" },
                  "session": { "$ref": "#/definitions/Session" }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "400": {
          "description": "Token expired or invalid",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "Invite link expired. Request a new one." },
              "error_code": { "type": "string", "enum": ["EXPIRED_TOKEN", "INVALID_TOKEN", "CONSUMED_TOKEN"], "example": "EXPIRED_TOKEN" }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "User": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "email": { "type": "string", "format": "email" },
        "full_name": { "type": "string" },
        "role": { "type": "string", "enum": ["dispatcher_admin", "carrier_free", "carrier_pro", "carrier_fleet"] },
        "carrier_id": { "type": "string", "format": "uuid", "nullable": true },
        "organization_id": { "type": "string", "format": "uuid" }
      }
    },
    "Session": {
      "type": "object",
      "properties": {
        "access_token": { "type": "string" },
        "refresh_token": { "type": "string" },
        "expires_at": { "type": "string", "format": "date-time" }
      }
    },
    "Organization": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "name": { "type": "string" },
        "slug": { "type": "string" },
        "plan": { "type": "string" }
      }
    }
  }
}
