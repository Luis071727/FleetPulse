{
  "api": "AI Intelligence",
  "version": "1.0.0",
  "baseUrl": "/api/v1/ai",
  "description": "Server-side Claude integration for load recommendations, broker scoring, and invoice follow-ups. All calls use prompt caching for efficiency.",
  "endpoints": [
    {
      "name": "Analyze Load",
      "method": "POST",
      "path": "/load/analyze",
      "description": "Generate GO/NEGOTIATE/PASS recommendation for a load (P4 gate)",
      "auth": "Bearer (internal, backend-only, NOT exposed to frontend)",
      "requestBody": {
        "type": "object",
        "required": ["load_id"],
        "properties": {
          "load_id": { "type": "string", "format": "uuid" },
          "force_refresh": {
            "type": "boolean",
            "default": false,
            "description": "Skip cache; re-generate recommendation"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Recommendation generated (or cached)",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "load_id": { "type": "string", "format": "uuid" },
                  "recommendation": { "type": "string", "enum": ["GO", "NEGOTIATE", "PASS"] },
                  "reasoning": {
                    "type": "string",
                    "description": "Narrative explanation of thresholds (RPM, trust, carrier status)"
                  },
                  "target_rate": {
                    "type": "number",
                    "nullable": true,
                    "description": "Suggested negotiation target rate in USD. Present only when recommendation is NEGOTIATE.",
                    "example": 2100
                  },
                  "summary_metrics": {
                    "type": "object",
                    "properties": {
                      "net_rpm": { "type": "number", "example": 1.35 },
                      "broker_trust_score": { "type": "number", "example": 72.5 },
                      "carrier_status": { "type": "string" },
                      "go_threshold_met": { "type": "boolean" },
                      "negotiate_threshold_met": { "type": "boolean" }
                    }
                  },
                  "cache_hit": { "type": "boolean", "description": "true if retrieved from 30-day AI response cache" },
                  "tokens_used": {
                    "type": "object",
                    "properties": {
                      "input": { "type": "integer" },
                      "output": { "type": "integer" },
                      "cache_creation": { "type": "integer", "nullable": true },
                      "cache_read": { "type": "integer", "nullable": true }
                    }
                  }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "503": {
          "description": "Claude API error or rate limit",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "Claude API rate limit exceeded" },
              "error_code": { "type": "string", "example": "AI_SERVICE_UNAVAILABLE" },
              "retry_after_seconds": { "type": "integer", "example": 30, "description": "Suggested wait time before retry" }
            }
          }
        }
      }
    },
    {
      "name": "Score Broker",
      "method": "POST",
      "path": "/broker/score",
      "description": "Compute trust score for a broker (new or existing)",
      "auth": "Bearer (internal)",
      "requestBody": {
        "type": "object",
        "required": ["broker_id"],
        "properties": {
          "broker_id": { "type": "string", "format": "uuid" },
          "force_fmcsa_refresh": {
            "type": "boolean",
            "default": false,
            "description": "By-pass FMCSA cache and pull fresh data"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Broker trust score computed",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "broker_id": { "type": "string", "format": "uuid" },
                  "trust_score": { "type": "number", "minimum": 0, "maximum": 100, "example": 72.5 },
                  "source": {
                    "type": "string",
                    "enum": ["fmcsa", "payment_history", "hybrid"],
                    "description": "Data source for score"
                  },
                  "components": {
                    "type": "object",
                    "properties": {
                      "fmcsa_authority_pct": { "type": "number", "nullable": true },
                      "fmcsa_operating_history_pct": { "type": "number", "nullable": true },
                      "payment_days_avg": { "type": "integer", "nullable": true },
                      "payment_days_p90": { "type": "integer", "nullable": true },
                      "late_payment_rate": { "type": "number", "nullable": true },
                      "fraud_flags": { "type": "array", "items": { "type": "string" } }
                    }
                  },
                  "recommendation": {
                    "type": "string",
                    "enum": ["GO", "NEGOTIATE", "CAUTION"],
                    "description": "Score-based dispatcher guidance"
                  }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "name": "Draft Invoice Follow-up",
      "method": "POST",
      "path": "/invoice/followup",
      "description": "Generate AI follow-up message for overdue invoice (P5 gate)",
      "auth": "Bearer (internal)",
      "requestBody": {
        "type": "object",
        "required": ["invoice_id"],
        "properties": {
          "invoice_id": { "type": "string", "format": "uuid" },
          "override_tone": {
            "type": "string",
            "enum": ["polite", "firm", "assertive", "final"],
            "description": "Force tone regardless of days_outstanding. Uses constitutional rules: 7-14d polite, 15-21d firm, 22-29d assertive, 30+ final"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Follow-up draft generated",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "invoice_id": { "type": "string", "format": "uuid" },
                  "followup_count": { "type": "integer", "description": "Number of this follow-up (1, 2, 3+)" },
                  "tone": { "type": "string" },
                  "draft_message": { "type": "string", "description": "Ready-to-send email body" },
                  "subject_line": { "type": "string", "example": "Payment Reminder: Invoice 12345" },
                  "cache_hit": { "type": "boolean" },
                  "tokens_used": {
                    "type": "object",
                    "properties": {
                      "input": { "type": "integer" },
                      "output": { "type": "integer" }
                    }
                  }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "name": "Generate Insurance Playbook (Phase 2)",
      "method": "POST",
      "path": "/insurance/playbook",
      "description": "Generate IRS-focused recommendations for a carrier (P7 gate, Phase 2 only)",
      "auth": "Bearer (internal)",
      "requestBody": {
        "type": "object",
        "required": ["carrier_id"],
        "properties": {
          "carrier_id": { "type": "string", "format": "uuid" },
          "include_driver_profiles": {
            "type": "boolean",
            "default": false,
            "description": "Include driver MVR analysis if available"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Insurance playbook generated",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "carrier_id": { "type": "string", "format": "uuid" },
                  "irs_score": { "type": "number", "minimum": 0, "maximum": 100 },
                  "irs_sub_scores": {
                    "type": "object",
                    "properties": {
                      "safety": { "type": "number" },
                      "drivers": { "type": "number" },
                      "compliance": { "type": "number" },
                      "fleet": { "type": "number" },
                      "technology": { "type": "number" },
                      "readiness": { "type": "number" }
                    }
                  },
                  "playbook_draft": {
                    "type": "string",
                    "description": "Multi-paragraph narrative with: current standing, risk areas, improvement priorities, compliance actions"
                  },
                  "data_quality": {
                    "type": "object",
                    "properties": {
                      "csa_score_age_days": { "type": "integer" },
                      "driver_mvr_coverage_pct": { "type": "number", "nullable": true },
                      "missing_fields": { "type": "array", "items": { "type": "string" } }
                    }
                  },
                  "cache_hit": { "type": "boolean" },
                  "tokens_used": {
                    "type": "object",
                    "properties": {
                      "input": { "type": "integer" },
                      "output": { "type": "integer" },
                      "cache_creation": { "type": "integer", "nullable": true }
                    }
                  }
                }
              },
              "error": { "type": "null" }
            }
          },
          "note": "Phase 2 endpoint; returns 501 Not Implemented if called during Phase 1"
        },
        "501": {
          "description": "Phase 2 feature not yet available",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "Insurance Intelligence (Phase 2) not yet available" }
            }
          }
        }
      }
    }
  ],
  "design_notes": {
    "prompt_caching": "All Claude calls use system prompts cached for 5-minute ephemeral window. Typical cache hit rate 60-80% within single session.",
    "response_storage": "All AI responses stored in ai_responses table (JSON + metadata) with 30-day TTL for auditability and reuse.",
    "token_counting": "Instrumented in each response for cost tracking and optimization.",
    "confidentiality": "All AI endpoints internal-only; FastAPI guards against frontend direct invocation. Responses include dispatcher-safe reasoning only (no sensitive carrier data)."
  }
}
