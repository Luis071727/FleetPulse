{
  "api": "Brokers",
  "version": "1.0.0",
  "baseUrl": "/api/v1/brokers",
  "description": "Broker data access with trust scoring. Read-only for dispatchers; internal endpoints manage trust computation.",
  "endpoints": [
    {
      "name": "List Brokers",
      "method": "GET",
      "path": "/",
      "description": "Fetch brokers in organization with trust scores",
      "auth": "Bearer (dispatcher_admin, carrier_*)",
      "queryParams": {
        "type": "object",
        "properties": {
          "trust_score_min": {
            "type": "number",
            "description": "Filter by minimum trust score (0-100)"
          },
          "trust_score_max": {
            "type": "number",
            "description": "Filter by maximum trust score"
          },
          "has_fraud_flags": {
            "type": "boolean",
            "description": "Filter to show only brokers with fraud flags"
          },
          "payment_days_avg_max": {
            "type": "integer",
            "description": "Filter by average payment days threshold"
          },
          "sort_by": {
            "type": "string",
            "enum": ["trust_score", "legal_name", "payment_days_avg", "late_payment_rate"],
            "default": "trust_score",
            "description": "Sort column"
          },
          "order": {
            "type": "string",
            "enum": ["asc", "desc"],
            "default": "desc"
          },
          "limit": { "type": "integer", "default": 50, "maximum": 500 },
          "offset": { "type": "integer", "default": 0 }
        }
      },
      "responses": {
        "200": {
          "description": "Broker list (RLS-scoped to organization)",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "array",
                "items": { "$ref": "#/definitions/Broker" }
              },
              "meta": {
                "type": "object",
                "properties": {
                  "total": { "type": "integer" },
                  "avg_trust_score": { "type": "number" },
                  "limit": { "type": "integer" },
                  "offset": { "type": "integer" }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    },
    {
      "name": "Get Broker Details",
      "method": "GET",
      "path": "/{broker_id}",
      "description": "Fetch single broker with full trust score breakdown",
      "auth": "Bearer",
      "pathParams": {
        "broker_id": { "type": "string", "format": "uuid" }
      },
      "responses": {
        "200": {
          "description": "Broker detail",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "allOf": [{ "$ref": "#/definitions/Broker" }],
                "properties": {
                  "trust_score_components": {
                    "type": "object",
                    "properties": {
                      "fmcsa_authority_weight": { "type": "number", "example": 0.7 },
                      "fmcsa_authority_pct": { "type": "number", "nullable": true, "example": 95 },
                      "fmcsa_operating_history_pct": { "type": "number", "nullable": true, "example": 88 },
                      "payment_history_weight": { "type": "number", "example": 0.3 },
                      "payment_days_avg": { "type": "integer", "nullable": true },
                      "payment_days_p90": { "type": "integer", "nullable": true },
                      "late_payment_rate": { "type": "number", "nullable": true, "description": "% of invoices paid >30 days late" }
                    }
                  },
                  "fraud_risk_assessment": {
                    "type": "object",
                    "properties": {
                      "flags": { "type": "array", "items": { "type": "string" } },
                      "severity": { "type": "string", "enum": ["none", "low", "medium", "high"] }
                    }
                  },
                  "recent_loads": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "id": { "type": "string", "format": "uuid" },
                        "carrier_legal_name": { "type": "string" },
                        "rate": { "type": "number" },
                        "created_at": { "type": "string", "format": "date-time" }
                      }
                    },
                    "description": "Last 10 loads from this broker"
                  }
                }
              },
              "error": { "type": "null" }
            }
          }
        },
        "404": {
          "description": "Broker not found",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string" }
            }
          }
        }
      }
    },
    {
      "name": "Search Brokers by MC Number",
      "method": "GET",
      "path": "/mc/{mc_number}",
      "description": "Look up broker by MC number (FMCSA registration number)",
      "auth": "Bearer (dispatcher_admin)",
      "pathParams": {
        "mc_number": { "type": "string", "pattern": "^MC\\d+$|^\\d+$", "example": "123456" }
      },
      "responses": {
        "200": {
          "description": "Broker found or will be created on first load assignment",
          "body": {
            "type": "object",
            "properties": {
              "data": { "$ref": "#/definitions/Broker" },
              "note": {
            "type": "string",
            "example": "Broker registered with FMCSA on 2024-01-15. Trust score based on authority 70% + operating history 30%."
              },
              "error": { "type": "null" }
            }
          }
        },
        "404": {
          "description": "MC number not found in FMCSA or local database",
          "body": {
            "type": "object",
            "properties": {
              "data": { "type": "null" },
              "error": { "type": "string", "example": "MC123456 not found. Contact FMCSA or check number." }
            }
          }
        }
      }
    }
  ],
  "internal_endpoints": [
    {
      "name": "[Internal] Refresh Broker Trust Score",
      "method": "POST",
      "path": "/internal/refresh-trust-score/{broker_id}",
      "description": "Rebuild trust score from FMCSA data and payment history (called after FMCSA cache refresh or new invoice paid)",
      "auth": "Bearer (backend-only, secret key)",
      "pathParams": {
        "broker_id": { "type": "string", "format": "uuid" }
      },
      "requestBody": {
        "type": "object",
        "properties": {
          "force_fmcsa_pull": {
            "type": "boolean",
            "default": false,
            "description": "Force fresh FMCSA lookup (bypass 24h cache)"
          }
        }
      },
      "responses": {
        "200": {
          "description": "Trust score updated",
          "body": {
            "type": "object",
            "properties": {
              "data": {
                "type": "object",
                "properties": {
                  "broker_id": { "type": "string", "format": "uuid" },
                  "trust_score_before": { "type": "number" },
                  "trust_score_after": { "type": "number" },
                  "source": { "type": "string" }
                }
              },
              "error": { "type": "null" }
            }
          }
        }
      }
    }
  ],
  "definitions": {
    "Broker": {
      "type": "object",
      "properties": {
        "id": { "type": "string", "format": "uuid" },
        "organization_id": { "type": "string", "format": "uuid" },
        "mc_number": {
          "type": "string",
          "unique": true,
          "example": "123456",
          "description": "FMCSA MC (Motor Carrier) number"
        },
        "legal_name": { "type": "string", "example": "ABC Logistics Inc." },
        "authority_status": {
          "type": "string",
          "enum": ["active", "inactive", "unknown"],
          "description": "FMCSA authority status"
        },
        "trust_score": {
          "type": "number",
          "minimum": 0,
          "maximum": 100,
          "example": 72.5,
          "description": "Composite trust score: 70% FMCSA authority + 30% payment history (or 100% FMCSA if no payment history)"
        },
        "trust_score_source": {
          "type": "string",
          "enum": ["fmcsa", "payment_history", "hybrid"],
          "example": "hybrid",
          "description": "fmcsa=no payment history yet, payment_history=old FMCSA data, hybrid=both fresh"
        },
        "payment_days_avg": {
          "type": "integer",
          "nullable": true,
          "example": 18,
          "description": "Average days to payment across all loads"
        },
        "payment_days_p90": {
          "type": "integer",
          "nullable": true,
          "example": 35,
          "description": "90th percentile days to payment (worst case)"
        },
        "late_payment_rate": {
          "type": "number",
          "nullable": true,
          "example": 0.08,
          "description": "Fraction of invoices paid >30 days late"
        },
        "fraud_flags": {
          "type": "array",
          "items": { "type": "string" },
          "example": ["duplicate_mc_number_at_different_address"],
          "description": "List of risk indicators from FMCSA or internal checks"
        },
        "fmcsa_last_pulled_at": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of last FMCSA lookup"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "updated_at": { "type": "string", "format": "date-time" }
      }
    }
  }
}
