# ── Supabase ──
APP_NAME=FleetPulse API
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_KEY=eyJ...your-service-role-key
# ⚠️  Use the service_role key (NOT the anon key) for the backend.
# Found in: Supabase Dashboard > Settings > API > service_role key

JWT_SECRET=your-supabase-jwt-secret
# Found in: Supabase Dashboard > Settings > API > JWT Secret

# ── AI (optional – threshold fallback works without it) ──
ANTHROPIC_KEY=

# ── Email (optional – Phase 2) ──
SENDGRID_KEY=

# ── FMCSA (optional – mock data used without it) ──
FMCSA_API_KEY=

# ── Deployment ──
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
# For production, set to your deployed frontend URL:
# CORS_ORIGINS=https://your-app.vercel.app
